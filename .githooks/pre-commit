#!/usr/bin/env bash
# Repo pre-commit hook: redaction gate (blocks OCIDs/IPs/namespaces/secrets in the
# staged diff). Enable with:  git config core.hooksPath .githooks   (or: npm run hooks:install)
set -euo pipefail
ROOT="$(git rev-parse --show-toplevel)"
if [ -x "$ROOT/scripts/check-redaction.sh" ]; then
    "$ROOT/scripts/check-redaction.sh"
else
    bash "$ROOT/scripts/check-redaction.sh"
fi

# Optional deep scan: gitleaks, if installed (brew install gitleaks). Skipped
# silently when absent — the redaction gate above is the mandatory baseline.
if command -v gitleaks >/dev/null 2>&1; then
    if ! gitleaks git --pre-commit --staged --no-banner --redact "$ROOT"; then
        printf '[pre-commit] gitleaks found potential secrets in the staged diff — commit blocked.\n' >&2
        exit 1
    fi
else
    printf '[pre-commit] gitleaks not installed — skipping optional deep secret scan.\n'
fi
